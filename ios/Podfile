# Google AI Edge Gallery iOS and MediaPipe GenAI require a modern iOS target.
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

# Force flutter_gemma iOS to build only the .litertlm FFI runtime. The pub.dev
# podspec still declares MediaPipe pods for .task fallback, which forces a slow
# 422MB download and re-enters the broken MediaPipe path. Our iOS runtime only
# uses ModelFileType.litertlm, so patch the plugin podspec locally before pods
# are resolved.
flutter_gemma_podspec = File.expand_path(File.join('..', '.symlinks', 'plugins', 'flutter_gemma', 'ios', 'flutter_gemma.podspec'), __FILE__)
if File.exist?(flutter_gemma_podspec)
  spec = File.read(flutter_gemma_podspec)
  spec = spec.gsub(/\n\s*s\.dependency 'MediaPipeTasksGenAI'.*$/, '')
  spec = spec.gsub(/\n\s*s\.dependency 'MediaPipeTasksGenAIC'.*$/, '')
  spec = spec.gsub(/\n\s*s\.dependency 'TensorFlowLiteC'.*$/, '')
  File.write(flutter_gemma_podspec, spec)
end


target 'Runner' do
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
  end

  # flutter_gemma / LiteRT-LM: Native Assets bundle accelerator dylibs as
  # frameworks, while LiteRT-LM's GPU registry may dlopen by flat basename.
  # Add symlinks inside Runner.app/Frameworks for physical iOS devices.
  installer.aggregate_targets.each do |aggregate_target|
    aggregate_target.user_targets.each do |user_target|
      phase_name = '[flutter_gemma] Setup LiteRT-LM iOS dylib symlinks'
      phase = user_target.shell_script_build_phases.find { |p| p.name == phase_name } ||
              user_target.new_shell_script_build_phase(phase_name)
      phase.shell_script = <<~SHELL
        set -e
        FRAMEWORKS="${BUILT_PRODUCTS_DIR}/${PRODUCT_NAME}.app/Frameworks"
        if [ ! -d "${FRAMEWORKS}" ]; then
          echo "[flutter_gemma] no Frameworks dir, skipping"
          exit 0
        fi
        for base in LiteRtMetalAccelerator LiteRtTopKMetalSampler GemmaModelConstraintProvider; do
          src="${base}.framework/${base}"
          dst="${FRAMEWORKS}/lib${base}.dylib"
          if [ -e "${FRAMEWORKS}/${src}" ] && [ ! -e "${dst}" ]; then
            ln -sf "${src}" "${dst}"
            echo "[flutter_gemma] symlinked lib${base}.dylib -> ${src}"
          fi
        done
      SHELL
    end
  end
end
